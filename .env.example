# --------------------------------------------------------------------------
# Arham Always Care WhatsApp agent — environment variables.
# Copy to .env.local and fill in. NEVER commit real values to git.
# --------------------------------------------------------------------------

# --- Interakt (WhatsApp Business provider) --------------------------------
# Get from Interakt dashboard > Developer Settings > API Key.
INTERAKT_API_KEY=
# Custom token you set in Interakt > Webhook config. Sent on every inbound POST
# in the Interakt-Verify-Token header (mode = static, default).
INTERAKT_WEBHOOK_SECRET=
# "static" (default) or "hmac". Match what you've configured in Interakt.
INTERAKT_WEBHOOK_VERIFY_MODE=static
# Your Interakt-registered WhatsApp phone (display number) in E.164 form.
INTERAKT_PHONE_NUMBER=
# Override only if you're using a sandbox endpoint.
# INTERAKT_API_BASE=https://api.interakt.ai/v1/public/message/

# --- LLM provider ---------------------------------------------------------
# AI_MODEL is the routing key. Format: "<provider>/<model>". Switching
# providers is an env-var change only — no code change.
#
# Supported providers and the env vars each requires:
#   anthropic   → ANTHROPIC_API_KEY
#   openai      → OPENAI_API_KEY
#   google      → GOOGLE_API_KEY (also accepts GOOGLE_GENERATIVE_AI_API_KEY)
#   deepseek    → DEEPSEEK_API_KEY
#   groq        → GROQ_API_KEY
#   openrouter  → OPENROUTER_API_KEY
#   custom      → CUSTOM_AI_BASE_URL + CUSTOM_AI_API_KEY (any OpenAI-compatible API)
#
# Examples:
#   AI_MODEL=anthropic/claude-sonnet-4-6
#   AI_MODEL=anthropic/claude-opus-4-7
#   AI_MODEL=openai/gpt-5.1
#   AI_MODEL=google/gemini-2.5-pro
#   AI_MODEL=deepseek/deepseek-chat
#   AI_MODEL=openrouter/anthropic/claude-sonnet-4-6
AI_MODEL=anthropic/claude-sonnet-4-6

# Set the keys you actually use. Unused keys can stay empty.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Custom OpenAI-compatible endpoint (Together, Fireworks, self-hosted, etc.).
# Use AI_MODEL=custom/<model-name> with these set.
# CUSTOM_AI_BASE_URL=
# CUSTOM_AI_API_KEY=

# Cap on tool-loop steps per turn (safety against runaway loops).
AI_MAX_STEPS=5

# --- Supabase --------------------------------------------------------------
# From Supabase project settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — backend only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Arham internal APIs --------------------------------------------------
# Cases API (logs of treated animals). Used for opportunistic closure
# summaries; partner-handled cases that don't appear here will not get
# auto-summaries, by design.
CASES_API_BASE=
CASES_API_KEY=

# Ambulance GPS API (real-time position of every Arham-operated unit).
GPS_API_BASE=
GPS_API_KEY=

# --- Vercel Cron auth -----------------------------------------------------
# Optional shared secret for Vercel Cron requests; if set, the followup,
# closure, and idle cron handlers require this in the Authorization header.
CRON_SECRET=

# --- Followup tuning ------------------------------------------------------
# Minutes after delivering the driver's number before asking "did you connect?"
FOLLOWUP_DELAY_MIN=5

# --- App config ------------------------------------------------------------
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
