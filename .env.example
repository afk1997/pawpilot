# --------------------------------------------------------------------------
# Arham Always Care WhatsApp agent — environment variables.
# Copy to .env.local and fill in. NEVER commit real values to git.
# --------------------------------------------------------------------------

# --- Interakt (WhatsApp Business provider) --------------------------------
# Get from Interakt dashboard > Developer Settings > API Key.
INTERAKT_API_KEY=
# Custom token you set in Interakt > Webhook config. Sent on every inbound POST
# in the Interakt-Verify-Token header (mode = static, default).
INTERAKT_WEBHOOK_SECRET=
# "static" (default) or "hmac". Match what you've configured in Interakt.
INTERAKT_WEBHOOK_VERIFY_MODE=static
# Your Interakt-registered WhatsApp phone (display number) in E.164 form.
INTERAKT_PHONE_NUMBER=
# Override only if you're using a sandbox endpoint.
# INTERAKT_API_BASE=https://api.interakt.ai/v1/public/message/

# --- LLM provider via OpenRouter (Vercel AI SDK target) -------------------
OPENROUTER_API_KEY=
# Default Indic-strong, tool-capable model. Override per environment.
AI_MODEL=anthropic/claude-sonnet-4-6

# --- Supabase --------------------------------------------------------------
# From Supabase project settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — backend only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Arham internal APIs --------------------------------------------------
# Cases API (logs of treated animals). Used for opportunistic closure
# summaries; partner-handled cases that don't appear here will not get
# auto-summaries, by design.
CASES_API_BASE=
CASES_API_KEY=

# Ambulance GPS API (real-time position of every Arham-operated unit).
GPS_API_BASE=
GPS_API_KEY=

# --- Vercel Cron auth (per Vercel docs) -----------------------------------
# Optional shared secret to authenticate Vercel Cron requests; if set, the
# follow-up and closure cron handlers will require this in Authorization.
CRON_SECRET=

# --- App config ------------------------------------------------------------
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
