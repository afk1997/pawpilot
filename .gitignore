# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit any real values
.env
.env.local
.env.*.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
# Allow the template:
!.env.example

# secret-shaped files
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
private/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify
/graphify-out

# Arham private data (driver personal phone numbers, case exports) — keep local only
ambulances-clinics.csv
ambulances-clinics.xlsx
ambulances-clinics-*.csv
ambulances-clinics-*.xlsx
*.cases-export.json
*.cases-export.csv
arham-private/
